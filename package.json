{
  "name": "npm-ripe-guard",
  "version": "1.0.0",
  "description": "Local npm registry proxy that blocks packages published less than 24 hours ago",
  "scripts": {
    "build": "esbuild src/server.ts --bundle --platform=node --target=node18 --outfile=dist/server.js",
    "start": "node dist/server.js",
    "dev": "tsx --watch src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.12",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
